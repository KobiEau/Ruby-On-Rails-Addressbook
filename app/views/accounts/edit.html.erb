
<div class="max-w-lg mx-auto">
  <%= render "shared/back_link", text:"← Back to My Account",path: account_path%>

  <div class= "bg-[var(--color-surface-card)] border border-[var(--color-border-subtle)]
              rounded-lg shadow p-[var(--spacing-6)]">
  
    <h1 class="font-bold text-4xl">Edit Account</h1>

    <%=form_with model: @user, url: account_path do |form|%>

      <%# Error messages %>
      <% if @user.errors.any? %>
        <div class="bg-[var(--color-error-bg)] border border-[var(--color-error-border)]
                    text-[var(--color-error-text)] px-4 py-4 rounded-lg mb-[var(--spacing-6)]">
          <h2 class="font-bold mb-[var(--spacing-2)]">
            <%= pluralize(@user.errors.count, "error") %> prevented this contact from being saved
          </h2>
          <ul class="list-disc ml-5">
            <% @user.errors.full_messages.each do |message| %>
              <li class="text-sm"><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-[var(--spacing-4)]">
         <%= form.label :firstname,
          class: "block text-sm font-semibold text-[var(--color-label)] mb-[var(--spacing-2)]" %>
        <%= form.text_field :firstname, placeholder: "John",
              class: "w-full px-4 py-2 text-sm
                      bg-[var(--color-input-bg)]
                      text-[var(--color-text-heading)]
                      border border-[var(--color-input-border)]
                      rounded-lg
                      focus:outline-none focus:ring-2 focus:ring-[var(--color-input-focus)]
                      transition" %>
      </div>

      <div class="mb-[var(--spacing-4)]">
        <%= form.label :lastname,
              class: "block text-sm font-semibold text-[var(--color-label)] mb-[var(--spacing-2)]" %>
        <%= form.text_field :lastname, placeholder: "Doe",
              class: "w-full px-4 py-2 text-sm
                      bg-[var(--color-input-bg)]
                      text-[var(--color-text-heading)]
                      border border-[var(--color-input-border)]
                      rounded-lg
                      focus:outline-none focus:ring-2 focus:ring-[var(--color-input-focus)]
                      transition" %>
      </div>

      <div class="mb-[var(--spacing-4)]">
        <%= form.label :email_address,
            class: "block text-sm font-semibold 
                    text-[var(--color-label)] mb-[var(--spacing-2)]"%>
        <%= form.email_field :email_address,
            class: "w-full px-4 py-2 text-sm
                bg-[var(--color-input-bg)]
                text-[var(--color-text-heading)]
                border border-[var(--color-input-border)]
                rounded-lg
                focus:outline-none focus:ring-2 focus:ring-[var(--color-input-focus)]
                transition"%>
      </div>
    
      <div class="flex flex-col items-center gap-[var(--spacing-3)]">
        <%= form.submit "Update Account",
            class: "px-5 py-2 text-sm font-bold
                    bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)]
                    text-[var(--color-text-on-accent)]
                    rounded-lg cursor-pointer
                    transition-colors duration-200 "%>
      </div>
    <%end%>

  </div>

</div>





<%# Danger Zone — separate card %>
<div class="max-w-lg mx-auto mt-[var(--spacing-6)]">
  <div class="bg-[var(--color-error-bg)] border border-[var(--color-error-border)]
              rounded-lg shadow p-[var(--spacing-6)]">

    <h2 class="text-lg font-black text-[var(--color-error-text)] mb-[var(--spacing-2)]">
      Danger Zone
    </h2>
    <p class="text-sm text-[var(--color-error-text)] mb-[var(--spacing-4)]">
      Deleting your account is permanent and cannot be undone.
      All your contacts will be lost.
    </p>

    <hr class="border-[var(--color-error-border)] mb-[var(--spacing-4)]">

    <%= form_with url: account_path, method: :delete do |form| %>

      <div class="mb-[var(--spacing-4)]">
        <%= label_tag :current_password, "Confirm your password to proceed",
              class: "block text-sm font-semibold text-[var(--color-error-text)] mb-[var(--spacing-2)]" %>
        <%= render "shared/password_field",
              field_name: :current_password,
              placeholder: "Enter your password" %>
      </div>

      <%= form.submit "Delete My Account",
            data: { turbo_confirm: "This will permanently delete your account. Are you sure?" },
            class: "px-5 py-2 text-sm font-bold
                    bg-[var(--color-btn-danger)] hover:bg-[var(--color-btn-danger-hover)]
                    text-white rounded-lg cursor-pointer
                    transition-colors duration-200" %>
    <% end %>

  </div>
</div>