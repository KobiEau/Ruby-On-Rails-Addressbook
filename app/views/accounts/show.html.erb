<div class= "max-w-lg mx-auto">
  <%# Back Button %>
 <%= render "shared/back_link", text:"← Back to Contacts",path: contacts_path%>

  <div class="bg-[var(--color-surface-card)] border border-[var(--color-border-subtle)]
            rounded-lg shadow p-[var(--spacing-6)] mb-[var(--spacing-6)]">
    
    <div class="flex items-center gap-[var(--spacing-4)]">
    <%# Avatar  %>
    <div class=" <%= contact_initials_color(@user)%>
    w-16 h-16 rounded-full shrink-0
                flex items-center justify-center
                text-white font-bold text-2xl">
      <%= contact_initials(@user)%>
    </div>

    <div>
      <h1 class="text-xl font-bold uppercase tracking-widest"> My Account </h1>
      <p><strong>Name: </strong><%=@user.fullname%></p>
      <p><strong>Email: </strong><%= @user.email_address%></p>
    </div>

  </div>

  <div class= "bg-[var(--color-surface-card)] border border-[var(--color-border-subtle)]
              rounded-lg shadow p-[var(--spacing-6)]">
  
    <h2 class="text-xs font-bold uppercase tracking-widest
                text-[var(--color-text-body)]
                border-b border-[var(--color-divider)]
                pb-[var(--spacing-3)] mb-[var(--spacing-4)]">Account Settings</h2>

    <%# Two link_to buttons side by side — which tokens handle secondary and danger buttons? %>
    <div class="flex items-center gap-[var(--spacing-3)]">
      <%= link_to "Edit Account", edit_account_path,
              class: "px-4 py-2 text-sm font-semibold
                      bg-[var(--color-btn-secondary)] hover:bg-[var(--color-btn-secondary-hover)]
                      text-white rounded-lg transition-colors duration-200" %>

        <%= link_to "Change Password", edit_password_account_path,
              class: "px-4 py-2 text-sm font-semibold
                      bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)]
                      text-white rounded-lg transition-colors duration-200" %>

    </div>

  </div>

  <%# Import & Export card %>
<div class="bg-[var(--color-surface-card)] border border-[var(--color-border-subtle)]
            rounded-lg shadow p-[var(--spacing-6)] mt-[var(--spacing-6)]">

  <h2 class="text-xs font-bold uppercase tracking-widest
             text-[var(--color-text-body)]
             border-b border-[var(--color-divider)]
             pb-[var(--spacing-3)] mb-[var(--spacing-4)]">
    Contacts Data
  </h2>

  <div class="flex flex-col gap-[var(--spacing-4)]">

    <%# Export %>
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-semibold text-[var(--color-text-heading)] m-0">
          Export Contacts
        </p>
        <p class="text-xs text-[var(--color-text-body)] m-0">
          Download all your contacts as a CSV file
        </p>
      </div>
      <%= link_to "Export CSV", export_contacts_path(format: :csv),
            onclick: "return confirm('Are you sure you want to export all contacts?')",
            class: "px-4 py-2 text-sm font-semibold
                    bg-[var(--color-btn-tertiary-2)] hover:bg-[var(--color-btn-tertiary-2-hover)]
                    text-white rounded-lg transition-colors duration-200 whitespace-nowrap" %>
    </div>

    <hr class="border-[var(--color-divider)]">
    
     <%# Import %>
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-semibold text-[var(--color-text-heading)] m-0">
          Import Contacts
        </p>
        <p class="text-xs text-[var(--color-text-body)] m-0">
          Add contacts from a CSV file
        </p>
      </div>
      <%= link_to "Import CSV", import_contacts_path,
      class: "px-4 py-2 text-sm font-semibold
              bg-[var(--color-btn-tertiary-3)] hover:bg-[var(--color-btn-tertiary-3-hover)]
              text-white rounded-lg transition-colors duration-200 whitespace-nowrap" %>
    </div>

</div>
