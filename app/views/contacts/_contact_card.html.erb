<div class="bg-white rounded-lg border border-slate-200 shadow p-6">
  <!-- Card container: white background, rounded corners, shadow, padding -->
  
  <!-- Avatar with initials -->
  <div class="flex items-center mb-4">
    <div class="<%= contact_initials_color(contact) %> text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-lg">
      <%= contact_initials(contact) %>
    </div>

    <div class="ml-4">
      <!-- ml-4: margin left (space from avatar) -->
      <h3 class="text-lg font-bold text-slate-900">
        <%= contact.firstname %> <%= contact.lastname %>
      </h3>
      <p class="text-sm text-slate-600">
        <%#= contact.phone_number %>
      </p>
    </div>
  </div>

  <!-- Action buttons -->
  <div class="flex gap-2 mt-4">
    <!-- gap-2: small space between buttons -->
    <%= link_to "Show", contact_path(contact), class: "flex-1 bg-slate-700 text-white px-3 py-2 rounded text-center hover:bg-slate-600" %>
    <%= link_to "Edit", edit_contact_path(contact), class: "flex-1 bg-slate-700 text-white px-3 py-2 rounded text-center hover:bg-slate-600" %>
    <%= button_to "Delete", contact_path(contact), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "flex-1 bg-red-600 text-white px-3 py-2 rounded hover:bg-red-700" %>
  </div>
</div>