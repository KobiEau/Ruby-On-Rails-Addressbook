<div class="bg-[var(--color-surface-card)] rounded-lg border border-[var(--color-border-subtle)] shadow p-6">

  <%# Avatar + Name %>
  <div class="flex items-center mb-4">
    <div class="<%= contact_initials_color(contact) %> text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-lg shrink-0">
      <%= contact_initials(contact) %>
    </div>

    <div class="ml-4">
      <h3 class="text-lg font-bold text-[var(--color-text-heading)]">
        <%= contact.firstname %> <%= contact.lastname %>
      </h3>
      <p class="text-sm text-[var(--color-text-body)]">
        <%#= contact.phone_number %>
      </p>
    </div>
  </div>

  <%# Single view action %>
  <div class="mt-4">
    <%= link_to "View Contact", contact_path(contact),
          class: "block w-full text-center text-sm font-semibold px-3 py-2
                  bg-[var(--color-btn-card)] hover:bg-[var(--color-btn-card-hover)]
                  text-[var(--color-text-on-accent)]
                  rounded-[var(--radius-md)]
                  transition-colors duration-200" %>
  </div>

</div>