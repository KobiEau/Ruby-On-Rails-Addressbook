<%= form_with(model: contact, local: true) do |form|%>
  <%if contact.errors.any?%>
    <div class="bg-red 100 border border-red-400 text-red-700 px-4 py-4 rounded mb-4">
      <h2 class="font-bold"><%= pluralize(contact.errors.count,"errors")%> prohibit this contact from being saved </h2>
      <ul class= "list-disc ml-5 mt-2">
        <% contact.errors.full_messages.each do |message|%>
        <li><%= message%></li>
        <%end%>
      </ul>
    </div>
  <%end%>

  <div class="mb-4">
    <%= form.label :firstname, class: "block text-slate-700 font-bold mb-2" %>
    <%= form.text_field :firstname, placeholder:"John",class: "w-full px-3 py-2 border border-slate-300 rounded" %>
  </div>

  <div class="mb-4">
    <%= form.label :lastname, class: "block text-slate-700 font-bold mb-2" %>
    <%= form.text_field :lastname, placeholder:"Doe" ,class: "w-full px-3 py-2 border border-slate-300 rounded" %>
  </div>

  <div class="mb-4">
    <%= form.label :phone_number, class: "block text-slate-700 font-bold mb-2" %>
    <%= form.text_field :phone_number, placeholder: "0200000000",class: "w-full px-3 py-2 border border-slate-300 rounded" %>
  </div>

  <div class="action">
    <%= form.submit class:"bg-slate-700 text-white px-4 py-2 rounded hover:bg-slate-600"%>
  </div>
<% end%>