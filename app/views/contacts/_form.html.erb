<%= form_with(model: contact, local: true) do |form| %>

  <%# Error messages %>
  <%= render "shared/error_block", record: @contact%>

  <%# Firstname %>
  <div class="mb-[var(--spacing-4)]">
    <%= form.label :firstname,
          class: "block text-sm font-semibold text-[var(--color-label)] mb-[var(--spacing-2)]" %>
    <%= form.text_field :firstname, placeholder: "John",
          class: "w-full px-4 py-2 text-sm
                  bg-[var(--color-input-bg)]
                  text-[var(--color-text-heading)]
                  border border-[var(--color-input-border)]
                  rounded-lg
                  focus:outline-none focus:ring-2 focus:ring-[var(--color-input-focus)]
                  transition" %>
  </div>

  <%# Lastname %>
  <div class="mb-[var(--spacing-4)]">
    <%= form.label :lastname,
          class: "block text-sm font-semibold text-[var(--color-label)] mb-[var(--spacing-2)]" %>
    <%= form.text_field :lastname, placeholder: "Doe",
          class: "w-full px-4 py-2 text-sm
                  bg-[var(--color-input-bg)]
                  text-[var(--color-text-heading)]
                  border border-[var(--color-input-border)]
                  rounded-lg
                  focus:outline-none focus:ring-2 focus:ring-[var(--color-input-focus)]
                  transition" %>
  </div>

  <%# Phone %>
  <div class="mb-[var(--spacing-6)]">
    <%= form.label :phone_number,
          class: "block text-sm font-semibold text-[var(--color-label)] mb-[var(--spacing-2)]" %>
    <%= form.text_field :phone_number, placeholder: "0200000000",  maxlength: 10, pattern: "0[235][0-9]{8}",inputmode: "numeric",
          class: "w-full px-4 py-2 text-sm
                  bg-[var(--color-input-bg)]
                  text-[var(--color-text-heading)]
                  border border-[var(--color-input-border)] rounded-lg
                  focus:outline-none focus:ring-2 focus:ring-[var(--color-input-focus)]
                  transition" %>
  </div>

  <%# Submit %>
  <div class="flex items-center justify-between">
    <%= form.submit class: "px-5 py-2 text-sm font-bold
                  bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)]
                  text-[var(--color-text-on-accent)]
                  rounded-lg cursor-pointer
                  transition-colors duration-200" %>
                  
     <%= link_to "Cancel", contact.persisted? ? contact_path(contact) : contacts_path,
        class: "px-5 py-2 text-sm font-semibold
                border border-[var(--color-border-subtle)]
                bg-[var(--color-btn-cancel)]
                text-[var(--color-text-base)] hover:text-[var(--color-text-muted)]
                hover:border-[var(--color-text-muted)]
                rounded-lg transition-all duration-200" %>
  </div>

<% end %>