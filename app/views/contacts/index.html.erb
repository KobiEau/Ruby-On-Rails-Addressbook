<h1 class="text-3xl font-bold text-blue-600">Contacts</h1>

<h2>Welcome <%=Current.user.fullname%></h2>

<!-- Search form -->
<%= form_with url: contacts_path, method: :get, local: true do |form| %>
  <div class="mb-6 flex gap-2">
    <%= form.text_field :search, placeholder: "Search by name", class: "flex-1 px-3 py-2 border border-slate-300 rounded" %>
    <%= form.submit "Search", class: "bg-cyan-500 text-white px-4 py-2 rounded hover:bg-cyan-600" %>
  </div>
<% end %>

<!-- Contacts list -->
<% if @contacts.any? %>
  <div class="grid gap-4">
    <% @contacts.each do |contact| %>
      <div class="bg-white border border-slate-200 rounded-lg p-4 hover:shadow-lg transition">
        <div class="flex justify-between items-center">
          <div>
            <h2 class="text-xl font-bold text-slate-900"><%= contact.firstname %> <%= contact.lastname %></h2>
            <p class="text-slate-600"><%= contact.phone_number %></p>
          </div>
          <div class="flex gap-2">
            <%= link_to "Show", contact_path(contact), class: "text-cyan-500 hover:text-cyan-600" %>
            <%= link_to "Edit", edit_contact_path(contact), class: "text-cyan-500 hover:text-cyan-600" %>
            <%= button_to "Delete", contact_path(contact), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-700" %>
          </div>
        </div>
      </div>
    <% end %>
     <p> <%= link_to "Create Contact", new_contact_path, class: "bg-cyan-500 text-white px-4 py-2 rounded hover:bg-cyan-600" %></p>
  </div>
<% elsif params[:search].present? %>
  <p class="text-slate-600">No contacts match "<%= params[:search] %>". <%= link_to "Clear search", contacts_path, class: "text-cyan-500" %></p>
<% else %>
  <p class="text-slate-600">No contacts yet. <%= link_to "Create one", new_contact_path, class: "text-cyan-500" %></p>
<% end %>