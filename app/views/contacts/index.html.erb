<%# Page Header %>
<header class="mb-10 py-7 sticky top-10 z-40">
  <span class = "text-sm font-semibold uppercase tracking-widest mb-1">Welcome back,</span>
  <span class="text-sm font-semibold text-accent uppercase tracking-widest mb-1">
     <%= Current.user.fullname %>
  </span>
  <h1 class="text-4xl font-black tracking-tight">
    Your Contacts
  </h1>
  <span class="">Total contacts: <%= Current.user.contacts.count%></span>
</header>

<div data-controller="view-toggle export">

  <div class="flex flex-wrap items-center gap-3 mb-8 sticky top-48 z-40">
    <%= form_with url: contacts_path, method: :get, local: true, class: "flex-1 min-w-[200px]" do |form| %>
      <div class="flex gap-2">
        <%= form.text_field :search,
              placeholder: "Search by name…",
              value: params[:search],
              class: "flex-1 px-4 py-2 text-sm
                      bg-[var(--color-surface-input)]
                      border border-[var(--color-border-subtle)]
                      rounded-[var(--radius-md)]
                      focus:outline-none focus:ring-2 focus:ring-accent
                      transition" %>

        <%= form.submit "Search",
              class: "px-4 py-2 text-sm font-semibold
                      bg-surface-muted hover:bg-[var(--color-border-subtle)]
                      text-text-base
                      rounded-[var(--radius-md)]
                      cursor-pointer transition" %>
        
        <% if params[:search].present?%>
          <%= link_to "X Clear",contacts_path,
               class: "px-4 py-2 text-sm font-semibold
                  text-black
                  hover:text-[var(--color-danger)]
                  transition-colors duration-200"%>
        <%end%>
      </div>
    <% end %>

    <%= link_to new_contact_path,
          class: "shrink-0 px-4 py-2 text-sm font-bold
                  bg-accent hover:bg-accent-hover
                  text-text-on-accent
                  rounded-[var(--radius-md)]
                  shadow-[var(--shadow-btn)]
                  whitespace-nowrap transition-all duration-200" do %>
      + New Contact
    <% end %>

    <%# Export Selected button - disabled by default%>
    <%# <%= link_to "Export selected", export_selected_contacts_path, data: {disabled:true}%>
    <a id="export-btn",
      class="shrink-0 px-4 py-2 rounded-[var(--radius-md)]
              bg-[var(--color-accent)]
              text-[var(--color-text-on-accent)]
              font-semibold text-sm
              hover:bg-[var(--color-accent-hover)]
              transition-colors duration-200
              disabled:opacity-40 disabled:pointer-events-none"> Export Selected </a>

    <%# Uncheck all — hidden until a box is checked %>
    <button id="uncheck-btn"
            data-action="click->export#uncheckAll"
            class="hidden px-4 py-2 text-sm font-semibold
                  text-[var(--color-text-muted)]
                  hover:text-[var(--color-danger)]
                  transition-colors duration-200">
      ✕ Uncheck all
    </button>

    <%# Export search results (only visible when search is active)%>
    <% if params[:search].present?%>
      <%= link_to "Export \"#{params[:search]}\" results",
          export_selected_contacts_path(search:params[:search]),
          class:"shrink-0 px-4 py-2 rounded-[var(--radius-full)]
                bg-[var(--color-accent)]
                text-[var(--color-text-on-accent)]
                font-semibold text-sm
                hover:bg-[var(--color-accent-hover)]
                transition-colors duration-200"%>
    <%end%>

    <%# Toggle buttons %>
      <button data-action="click->view-toggle#switch"
            class="shrink-0 px-4 py-2 text-sm font-semibold
                  bg-[var(--color-view-toggle)] hover:bg-[var(--color-view-toggle-hover)]
                  text-white rounded-[var(--radius-md)] transition-colors duration-200 whitespace-nowrap">
      <span data-view-toggle-target="toggle-label">⊞ Table View</span>
    </button>
  </div>

    <div data-view-toggle-target="cardView">
      <%# Contacts grid %>
      <% if @contacts.any? %>
         <div class="flex items-center gap-2 mb-4 sticky top-59">
          <input type="checkbox"
                id="select-all-cards"
                class="w-4 h-4 accent-[var(--color-accent)] cursor-pointer select-all-checkbox" 
                data-action="change->export#selectAll">
          <label for="select-all-cards"
                class="text-sm text-[var(--color-text-muted)] cursor-pointer select-none">
            Select all
          </label>
        </div>

        <div class="grid grid-cols-1 xs:grid-cols-2 lg:grid-cols-3 gap-5 overflow-y-auto max-h-[300px]">
          <% @contacts.each do |contact| %>
          <div data-action="change->export#toggle">
            <%= render "contact_card", contact: contact %>
          </div>
          <% end %>
        </div>

      <% elsif params[:search].present? %>
        <div class="text-center py-20 text-text-muted">
          <p class="text-lg mb-2">No results for "<%= params[:search] %>"</p>
          <%= link_to "Clear search", contacts_path,
                class: "text-sm text-accent hover:underline" %>
        </div>

      <% else %>
        <div class="text-center py-20 text-text-muted">
          <p class="text-lg mb-2">No contacts yet.</p>
          <%= link_to "Create your first one →", new_contact_path,
                class: "text-sm text-accent hover:underline" %>
        </div>
      <% end %>

    </div>

    <%# Table view %>
    <div data-view-toggle-target="tableView" style="display:none" class="sticky top-62" >
      <% if @contacts.any? %>
        <div class="bg-[var(--color-surface-card)] border border-[var(--color-border-subtle)]
                    rounded-lg shadow overflow-hidden mb-6">
          <div class="max-h-96 overflow-auto">

            <table class="w-full text-sm min-w-[320px]">
              <thead class="sticky top-0  bg-[var(--color-surface-card)] z-10">
                <tr class="border-b border-[var(--color-border-subtle)]">
                  <%# New: checkbox column header with select-all %>
                  <th class="px-4 py-3 w-10">
                    <div class= "flex items-center gap-2">
                      <label for="select-all-cards"
                        class="text-xs font-bold uppercase tracking-widest
                              text-[var(--color-text-body)] cursor-pointer select-none">
                        Select all
                      </label>
                      <input type="checkbox" id="select-all-table"
                            class="w-4 h-4 accent-[var(--color-accent)] cursor-pointer select-all-checkbox"
                            data-action="change->export#selectAll" />    
                    </div>
                  </th>
                  <th class="text-left px-6 py-3 text-xs font-bold uppercase tracking-widest
                            text-[var(--color-text-body)]">Name</th>
                  <th class="hidden sm:table-cell text-left px-6 py-3 text-xs font-bold uppercase tracking-widest
                            text-[var(--color-text-body)]">Phone</th>
                  <th class="text-right px-6 py-3 text-xs font-bold uppercase tracking-widest
                            text-[var(--color-text-body)]">Action</th>
                </tr>
              </thead>
              <tbody>
                <% @contacts.each do |contact| %>
                  <tr data-action="click->contacts#show"
                  data-contacts-path ="<%= contact_path(contact)%>"
                  class="border-b border-[var(--color-border-subtle)] last:border-0 cursor-pointer
                            hover:bg-[var(--color-border-subtle)] transition-colors duration-150">
                    <%# New: per-row checkbox %>
                    <td class="px-4 py-4">
                      <input type="checkbox"
                              class="contact-checkbox w-4 h-4 accent-[var(--color-accent)] cursor-pointer"
                              value="<%= contact.id %>"
                              data-action="change->export#toggle">
                    </td>
                    <%# Avatar + Name %>
                    <td class="px-6 py-4">
                      <div class="flex items-center gap-[var(--spacing-3)]">
                        <div class="<%= contact_initials_color(contact) %>
                                    w-9 h-9 rounded-full shrink-0
                                    flex items-center justify-center
                                    text-white font-bold text-sm">
                          <%= contact_initials(contact) %>
                        </div>
                        <span class="font-semibold text-[var(--color-text-heading)]">
                          <%= contact.firstname %> <%= contact.lastname %>
                        </span>
                      </div>
                    </td>

                    <%# Phone %>
                    <td class="hidden sm:table-cell px-6 py-4 text-[var(--color-text-body)]">
                      <%= contact.phone_number %>
                    </td>

                    <%# Action %>
                    <td class="px-6 py-4 text-right">
                      <%= link_to "View More", contact_path(contact),
                            class: "px-3 py-1 text-xs font-semibold whitespace-nowrap
                                    bg-[var(--color-btn-card)] hover:bg-[var(--color-btn-card-hover)]
                                    text-white rounded-lg transition-colors duration-200" %>
                    </td>

                  </tr>
                <% end %>
              </tbody>
            </table>

          </div>
        </div>
      <% elsif params[:search].present? %>
        <div class="text-center py-20 text-[var(--color-text-muted)]">
          <p class="text-lg mb-2">No results for "<%= params[:search] %>"</p>
          <%= link_to "Clear search", contacts_path,
                class: "text-sm text-[var(--color-accent)] hover:underline" %>
        </div>
      <% else %>
        <div class="text-center py-20 text-[var(--color-text-muted)]">
          <p class="text-lg mb-2">No contacts yet.</p>
          <%= link_to "Create your first one →", new_contact_path,
                class: "text-sm text-[var(--color-accent)] hover:underline" %>
        </div>
      <% end %>
    </div>

  

    <%# Pagination footer %>
  <div class="flex items-center justify-between mt-[var(--spacing-6)]
                pt-[var(--spacing-4)] border-t border-[var(--color-border-subtle)] sticky top-500">
    <% if @contacts.total_pages >= 1 %>

      <%# Contact count %>
      <span class="text-sm text-[var(--color-text-muted)]">
        <%= form_with url: contacts_path, method: :get, local: true do |form| %>
      <%= form.hidden_field :search, value: params[:search] %>
      <%= form.select :per_page,
            [5, 10, 25, 50],
            { selected: params[:per_page] || 10 },
            {
              onchange: "this.form.submit()",
              class: "px-3 py-2 text-sm
                      bg-[var(--color-surface-input)]
                      text-black
                      border border-[var(--color-border-subtle)]
                      rounded-[var(--radius-md)]
                      cursor-pointer"
            } %>
      <% end %>
      </span>

      <%# Prev / Next %>
      <div class="flex items-center gap-[var(--spacing-2)]">
        <% if @contacts.prev_page %>
          <%= link_to "← Prev",
                contacts_path(page: @contacts.prev_page,
                              per_page: @per_page,
                              search: params[:search]),
                class: "px-4 py-2 text-sm font-semibold
                        bg-[var(--color-btn-secondary)] hover:bg-[var(--color-btn-secondary-hover)]
                        text-white rounded-[var(--radius-md)]
                        transition-colors duration-200" %>
        <% else %>
          <span class="px-4 py-2 text-sm font-semibold
                      bg-[var(--color-surface-muted)]
                      text-[var(--color-text-muted)]
                      rounded-[var(--radius-md)] opacity-50 cursor-not-allowed">
            ← Prev
          </span>
        <% end %>

        <%# Current page indicator %>
        <span class="px-3 py-2 text-sm text-[var(--color-text-muted)]">
          Page <%= @contacts.current_page %> of <%= @contacts.total_pages %>
        </span>

        <% if @contacts.next_page %>
          <%= link_to "Next →",
                contacts_path(page: @contacts.next_page,
                              per_page: @per_page,
                              search: params[:search]),
                class: "px-4 py-2 text-sm font-semibold
                        bg-[var(--color-btn-secondary)] hover:bg-[var(--color-btn-secondary-hover)]
                        text-white rounded-[var(--radius-md)]
                        transition-colors duration-200" %>
        <% else %>
          <span class="px-4 py-2 text-sm font-semibold
                      bg-[var(--color-surface-muted)]
                      text-[var(--color-text-muted)]
                      rounded-[var(--radius-md)] opacity-50 cursor-not-allowed">
            Next →
          </span>
        <% end %>
      </div>

    <% end %>
  </div>
</div>
<%# Search + New Contact toolbar %>