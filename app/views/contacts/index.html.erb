<header class="mb-8">
 <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">Contacts</h1>
  <p class="text-slate-500">Welcome back, <%= Current.user.fullname %></p>
</header>

<%# <div class="flex items-center justify-between mb-6">
  <div class="flex-1 mr-4">
    <button class="bg-amber-500 text-slate-900 px-4 py-2 rounded-lg font-bold hover:bg-amber-600 transition">
      Search
    </button>
  </div>
  <%= link_to "Create Contact", new_contact_path, class: "bg-amber-500 text-white px-4 py-2 rounded-lg font-medium hover:bg-slate-800 transition" %>
<%# </div> %> 

<!-- Search form -->
<div class="flex items-center justify-between mb-6">
  <%= form_with url: contacts_path, method: :get, local: true, class: "flex-1 mr-4" do |form| %>
    <div class="flex gap-2">
      <%= form.text_field :search, placeholder: "Search by name", class: "w-full px-3 py-2 border border-slate-300 rounded" %>
      <%= form.submit "Search", class: "bg-cyan-500 text-white px-4 py-2 rounded hover:bg-cyan-600 cursor-pointer" %>
    </div>
  <% end %>

  <%= link_to "Create Contact", new_contact_path, class: "bg-amber-500 text-white px-4 py-2 rounded hover:bg-amber-600 whitespace-nowrap" %>
</div>

<!-- Contacts list -->
<% if @contacts.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @contacts.each do |contact| %>
     <%= render "contact_card", contact: contact%>
    <% end %>
    
  </div>
<% elsif params[:search].present? %>
  <p class="text-slate-600">No contacts match "<%= params[:search] %>". <%= link_to "Clear search", contacts_path, class: "text-cyan-500" %></p>
<% else %>
  <p class="text-slate-600">No contacts yet. <%= link_to "Create one", new_contact_path, class: "text-cyan-500" %></p>
<% end %>