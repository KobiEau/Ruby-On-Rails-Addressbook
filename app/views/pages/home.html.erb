<main>
  <%# Hero %>
  <div class="min-h-screen flex flex-col items-center justify-center text-center
              px-6 py-[var(--spacing-8)]">

    <%# Icon %>
    <div class="w-16 h-16 rounded-full bg-accent flex items-center justify-center
                mb-[var(--spacing-6)] shadow-[var(--shadow-btn)]">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[var(--color-text-on-accent)]"
          fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857
                M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857
                m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
    </div>

    <%# Headline %>
    <h1 class="text-5xl font-black text-[var(--color-text-muted)] mb-[var(--spacing-4)]">
      Your contacts,<br>
      <span class="text-accent">all in one place.</span>
    </h1>

    <p class="text-lg text-[var(--color-text-muted)] max-w-md mb-[var(--spacing-8)]">
      Addressbook helps you store, search and manage your personal contacts — simply and privately.
    </p>

    <%# CTAs %>
    <div class="flex items-center gap-[var(--spacing-3)]">
      <%= link_to "Get Started", new_user_path,
            class: "px-6 py-3 text-sm font-bold
                    bg-accent hover:bg-accent-hover
                    text-[var(--color-text-on-accent)]
                    rounded-lg shadow-[var(--shadow-btn)]
                    transition-all duration-200" %>

      <%= link_to "Log In", new_session_path,
            class: "px-6 py-3 text-sm font-bold
                    bg-[var(--color-btn-secondary)] hover:bg-[var(--color-btn-secondary-hover)]
                    text-[var(--color-text-base)]
                    rounded-lg transition-all duration-200" %>
    </div>

  </div>

  <%# Features %>
  <div class="max-w-3xl mx-auto px-6 pb-[var(--spacing-4)]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[var(--spacing-6)]">

      <div class="bg-[var(--color-surface-raised)] border border-[var(--color-border)]
                  rounded-lg p-[var(--spacing-6)] text-center">
        <div class="text-accent text-2xl mb-[var(--spacing-3)]">📇</div>
        <h3 class="font-bold text-[var(--color-text-base)] mb-[var(--spacing-2)]">
          Store Contacts
        </h3>
        <p class="text-sm text-[var(--color-text-muted)] m-0">
          Save names, phone numbers in one organised place.
        </p>
      </div>

      <div class="bg-[var(--color-surface-raised)] border border-[var(--color-border)]
                  rounded-lg p-[var(--spacing-6)] text-center">
        <div class="text-accent text-2xl mb-[var(--spacing-3)]">🔍</div>
        <h3 class="font-bold text-[var(--color-text-base)] mb-[var(--spacing-2)]">
          Search Instantly
        </h3>
        <p class="text-sm text-[var(--color-text-muted)] m-0">
          Find any contact by name in seconds with live search.
        </p>
      </div>

      <div class="bg-[var(--color-surface-raised)] border border-[var(--color-border)]
                  rounded-lg p-[var(--spacing-6)] text-center">
        <div class="text-accent text-2xl mb-[var(--spacing-3)]">🔒</div>
        <h3 class="font-bold text-[var(--color-text-base)] mb-[var(--spacing-2)]">
          Private & Secure
        </h3>
        <p class="text-sm text-[var(--color-text-muted)] m-0">
          Your contacts are yours only — no one else can see them.
        </p>
      </div>

    </div>
  </div>

  <%# Footer %>
  <footer class="text-center text-xs text-[var(--color-text-muted)]
                py-[var(--spacing-6)] border-t border-[var(--color-border)]">
    <a href="https://www.flaticon.com/free-icons/address-book" title="address-book icons">Address-book icons created by Freepik - Flaticon</a>
    Addressbook &copy; <%= Date.today.year %> &middot; Built with Rails
  </footer>
</main>
