<nav class="bg-[var(--color-surface-raised)]
            shadow-[var(--shadow-navbar)]
            sticky top-0 z-50 w-full">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <%# ── Desktop layout — single row ── %>
    <div class="hidden sm:flex items-center justify-between h-16">

      <%# Logo left %>
      <%= link_to contacts_path,
            class: "flex items-center gap-2 shrink-0" do %>
        <svg xmlns="http://www.w3.org/2000/svg"
             class="w-5 h-5 text-[var(--color-accent)]"
             viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <span class="text-base font-bold text-[var(--color-text-base)]">
          <span class="text-[var(--color-accent)]">A</span>ddressbook
        </span>
      <% end %>

      <%# Links right %>
      <div class="flex items-center gap-6">
        <%= link_to "Contacts", contacts_path,
              class: "text-sm text-[var(--color-text-muted)]
                      hover:text-[var(--color-text-base)]
                      transition-colors duration-200" %>

        <%= link_to "Account", account_path,
              class: "text-sm text-[var(--color-text-muted)]
                      hover:text-[var(--color-text-base)]
                      transition-colors duration-200" %>

        <%= button_to "Log Out", session_path(Current.session),
              data: {turbo_confirm: "Are you sure?"},
              method: :delete,
              class: "text-sm text-[var(--color-text-muted)]
                      hover:text-[var(--color-danger)]
                      bg-transparent border-0 cursor-pointer
                      transition-colors duration-200" %>
      </div>
    </div>

    <%# ── Mobile layout — logo centered, links below ── %>
    <div class="sm:hidden flex flex-col items-center py-3 gap-3">

      <%# Logo centered %>
      <%= link_to contacts_path,
            class: "flex items-center gap-2" do %>
        <svg xmlns="http://www.w3.org/2000/svg"
             class="w-5 h-5 text-[var(--color-accent)]"
             viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <span class="text-base font-bold text-[var(--color-text-base)]">
          <span class="text-[var(--color-accent)]">A</span>ddressbook
        </span>
      <% end %>

      <%# Links horizontal tab bar %>
      <div class="flex items-center justify-around w-full
                  border-t border-[var(--color-border)] pt-2">

        <%= link_to contacts_path,
              class: "flex-1 text-center text-xs font-semibold
                      text-[var(--color-text-muted)]
                      hover:text-[var(--color-text-base)]
                      py-1 transition-colors duration-200" do %>
          <svg xmlns="http://www.w3.org/2000/svg"
               class="w-4 h-4 mx-auto mb-0.5" fill="none"
               viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
          </svg>
          Contacts
        <% end %>

        <%= link_to account_path,
              class: "flex-1 text-center text-xs font-semibold
                      text-[var(--color-text-muted)]
                      hover:text-[var(--color-text-base)]
                      py-1 transition-colors duration-200" do %>
          <svg xmlns="http://www.w3.org/2000/svg"
               class="w-4 h-4 mx-auto mb-0.5" fill="none"
               viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          Account
        <% end %>

        <%= button_to session_path(Current.session),
              method: :delete,
              data: {turbo_confirm: "Are you sure?"},
              form_class: "flex-1",
              class: "w-full text-center text-xs font-semibold
                      text-[var(--color-text-muted)]
                      hover:text-[var(--color-danger)]
                      bg-transparent border-0 cursor-pointer
                      py-1 transition-colors duration-200" do %>
          <svg xmlns="http://www.w3.org/2000/svg"
               class="w-4 h-4 mx-auto mb-0.5" fill="none"
               viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 0 1-3
                     3H6a3 3 0 0 1-3-3V7a3 3 0 0 1 3-3h4a3
                     3 0 0 1 3 3v1"/>
          </svg>
          Log Out
        <% end %>

      </div>
    </div>

  </div>
</nav>