<nav class="bg-surface-raised sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">

    <%# Logo %>
    <h1 class="text-xl font-black tracking-tight">
      <%= link_to contacts_path,
            class: "text-text-base hover:text-accent transition-colors duration-200" do %>
        <span class="text-accent">A</span>ddressbook
      <% end %>
    </h1>

    <%# Nav Links %>
    <div class="flex items-center gap-5">
      <% if authenticated? %>

        <%= link_to "Contacts", contacts_path,
              class: "text-sm font-medium text-text-muted
                      hover:text-text-base transition-colors duration-200" %>

        <%= link_to "My Account", account_path,
              class: "text-sm font-medium text-text-muted
                      hover:text-text-base transition-colors duration-200" %>

        <%= button_to "Log Out", session_path, method: :delete,
              class: "text-sm font-medium text-text-muted
                      hover:text-danger transition-colors duration-200
                      bg-transparent border-none cursor-pointer" %>

        <%#= link_to "New Contact", new_contact_path,
              class: "text-sm font-bold px-4 py-2
                      bg-accent hover:bg-accent-hover
                      text-text-on-accent
                      rounded-[var(--radius-md)]
                      shadow-[var(--shadow-btn)]
                      transition-all duration-200" %>

      <% else %>

        <%= link_to "Sign Up", new_user_path,
              class: "text-sm font-medium text-text-muted
                      hover:text-text-base transition-colors duration-200" %>

        <%= link_to "Log In", new_session_path,
              class: "text-sm font-bold px-4 py-2
                      bg-accent hover:bg-accent-hover
                      text-text-on-accent
                      rounded-[var(--radius-md)]
                      shadow-[var(--shadow-btn)]
                      transition-all duration-200" %>
      <% end %>
    </div>

  </div>
</nav>