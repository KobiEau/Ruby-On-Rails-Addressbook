        <%= button_to "Log Out", session_path, method: :delete, 
            class: "text-sm text-slate-400 hover:text-red-400 transition" %>
      <% else %>
        <%= link_to "Sign Up", new_user_path, class: "text-sm font-medium hover:text-amber-400" %>
