<nav class="bg-slate-900 text-slate-100 shadow-lg">
  <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
    <h1 class="text-2xl font-extrabold tracking-tight text-white hover:text-amber-400 transition-colors">
      <%= link_to "Addressbook", contacts_path %>
    </h1>
    
    <div class="flex items-center gap-6">
      <% if authenticated? %>
        <%= link_to "My Contacts", contacts_path, class: "text-sm font-medium hover:text-amber-400 transition" %>
        
