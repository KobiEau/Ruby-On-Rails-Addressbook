<%# Accepts: form (optional), field_name, placeholder %>
<div class="relative">
  <% if local_assigns[:form] %>
    <%= form.password_field field_name,
          placeholder: placeholder,
          class: "w-full px-4 py-2 pr-10 text-sm
                  bg-[var(--color-input-bg)]
                  text-[var(--color-text-heading)]
                  border border-[var(--color-input-border)]
                  rounded-lg
                  focus:outline-none focus:ring-2 focus:ring-[var(--color-input-focus)]
                  transition",
          id: "field_#{field_name}" %>
  <% else %>
    <%= password_field_tag field_name, nil,
          placeholder: placeholder,
          class: "w-full px-4 py-2 pr-10 text-sm
                  bg-[var(--color-input-bg)]
                  text-[var(--color-text-heading)]
                  border border-[var(--color-input-border)]
                  rounded-lg
                  focus:outline-none focus:ring-2 focus:ring-[var(--color-input-focus)]
                  transition",
          id: "field_#{field_name}" %>
  <% end %>

  <%# Toggle button %>
  <button type="button"
          onclick="togglePassword('field_<%= field_name %>', this)"
          class="absolute inset-y-0 right-3 flex items-center
                 text-[var(--color-text-muted)] hover:text-[var(--color-text-heading)]
                 transition-colors duration-200">
    <%# Eye icon — shown by default %>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none"
         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round"
            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
      <path stroke-linecap="round" stroke-linejoin="round"
            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943
               9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
    </svg>
  </button>
</div>